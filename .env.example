# Copy this file to `.env` and fill in your key. `.env` is gitignored.
# The key is read ONLY by the Node server process (Vite middleware) and is never
# bundled into the client. If unset, the app falls back to a local question bank.

ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used to generate questions.
# Defaults to claude-opus-4-8. Use claude-sonnet-5 for faster/cheaper generation.
# ASSESSMENT_MODEL=claude-sonnet-5
